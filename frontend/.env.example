# Personal Finance Management By Voicer Environment Variables Example

# Gemini AI API Key (required for transaction parsing)
GEMINI_API_KEY=

# Flask backend URL (production: https://finance-management-backend.onrender.com)
FLASK_BACKEND_URL=http://localhost:5000

# Google OAuth Client ID (for Sign in with Google)
VITE_GOOGLE_CLIENT_ID=

# Server Port
PORT="3000"
